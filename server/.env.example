# ─── Inserisci qui il token del bot Telegram ───
# Lo ottieni da @BotFather su Telegram (comando /newbot o /token).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID dove il bot invia i file audio (il tuo ID o un gruppo).
# Per scoprirlo: scrivi al bot, poi apri nel browser:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# Opzionale: protegge l'endpoint /upload (stesso valore in VITE_UPLOAD_SECRET sul frontend)
UPLOAD_SECRET=

# Porta locale (Render imposta PORT automaticamente)
PORT=3001
